{
  "thresholds": {
    "low": 20,
    "medium": 50,
    "high": 80
  },
  "event_rules": [
    {
      "id": "office_spawn_script",
      "name": "Office process launched a script interpreter",
      "score": 30,
      "match": {
        "event_type": "process_start",
        "parent_process_in": ["WINWORD.EXE", "EXCEL.EXE", "POWERPNT.EXE"],
        "process_name_in": ["powershell.exe", "cmd.exe", "wscript.exe", "cscript.exe"]
      }
    },
    {
      "id": "encoded_powershell",
      "name": "PowerShell used encoded command",
      "score": 25,
      "match": {
        "event_type": "process_start",
        "process_name_in": ["powershell.exe", "pwsh.exe"],
        "command_line_contains_any": ["-enc", "-encodedcommand"]
      }
    },
    {
      "id": "script_network_connection",
      "name": "Script interpreter made a network connection",
      "score": 20,
      "match": {
        "event_type": "network_connection",
        "process_name_in": ["powershell.exe", "cmd.exe", "wscript.exe", "cscript.exe", "python.exe"]
      }
    },
    {
      "id": "exe_created",
      "name": "Executable file was created",
      "score": 20,
      "match": {
        "event_type": "file_create",
        "file_path_endswith_any": [".exe", ".dll", ".scr", ".bat", ".ps1"]
      }
    },
    {
      "id": "many_file_modifications",
      "name": "Many files were modified in a short time",
      "score": 35,
      "match": {
        "event_type": "file_mass_modify",
        "modified_count_gte": 100
      }
    }
  ],
  "sequence_rules": [
    {
      "id": "download_execute",
      "name": "Created executable was launched soon",
      "score": 20,
      "within_seconds": 120,
      "sequence": ["file_create_executable", "process_start_same_file"]
    }
  ]
}

